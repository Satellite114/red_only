 262:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    existing ThreadX kernel awareness modules.  */
 263:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 264:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_THREAD_EXTENSION_0
 265:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_THREAD_EXTENSION_1
 266:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 267:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #ifdef  TX_ENABLE_IAR_LIBRARY_SUPPORT
 268:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* IAR library support */
 269:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #if !defined(TX_SINGLE_MODE_SECURE) && !defined(TX_SINGLE_MODE_NON_SECURE)
 270:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* ThreadX in non-secure zone with calls to secure zone. */
 271:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_THREAD_EXTENSION_2           VOID    *tx_thread_secure_stack_context;    \
 272:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****                                         VOID    *tx_thread_iar_tls_pointer;
 273:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #else
 274:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* ThreadX in only one zone. */
 275:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_THREAD_EXTENSION_2           VOID    *tx_thread_iar_tls_pointer;
 276:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #endif
 277:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 278:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #else
