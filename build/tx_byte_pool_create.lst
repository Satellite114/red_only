 141:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 142:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Determine if error checking is desired.  If so, map API functions
 143:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    to the appropriate error checking front-ends.  Otherwise, map API
 144:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    functions to the core functions that actually perform the work.
 145:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    Note: error checking is enabled by default.  */
 146:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 147:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #ifdef TX_DISABLE_ERROR_CHECKING
 148:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 149:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Services without error checking.  */
 150:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 151:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define tx_thread_secure_stack_allocate   _tx_thread_secure_stack_allocate
 152:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define tx_thread_secure_stack_free       _tx_thread_secure_stack_free
 153:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 154:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #else
 155:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 156:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Services with error checking.  */
 157:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 158:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define tx_thread_secure_stack_allocate   _txe_thread_secure_stack_allocate
 159:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define tx_thread_secure_stack_free       _txe_thread_secure_stack_free
 160:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 161:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #endif  /* TX_DISABLE_ERROR_CHECKING */
 162:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #endif  /* TX_SOURCE_CODE */
