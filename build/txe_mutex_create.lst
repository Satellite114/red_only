 174:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 175:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Define the minimum stack for a ThreadX thread on this processor. If the size supplied during
 176:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    thread creation is less than this value, the thread create call will return an error.  */
