 134:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Define the system API mappings based on the error checking
 135:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    selected by the user.  Note: this section is only applicable to
 136:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    application source code, hence the conditional that turns off this
 137:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    stuff when the include file is processed by the ThreadX source. */
 138:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 139:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #ifndef TX_SOURCE_CODE
 140:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 141:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 142:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Determine if error checking is desired.  If so, map API functions
 143:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    to the appropriate error checking front-ends.  Otherwise, map API
 144:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    functions to the core functions that actually perform the work.
 145:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    Note: error checking is enabled by default.  */
 146:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 147:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #ifdef TX_DISABLE_ERROR_CHECKING
