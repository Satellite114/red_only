 207:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /* Define the clock source for trace event entry time stamp. The following two item are port specif
 208:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    For example, if the time source is at the address 0x0a800024 and is 16-bits in size, the clock
 209:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h ****    source constants would be:
 210:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** 
 211:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_SOURCE                    *((volatile ULONG *) 0x0a800024)
 212:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_MASK                      0x0000FFFFUL
