  46:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    This function deletes the specified byte pool.  All threads         */
  47:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    suspended on the byte pool are resumed with the TX_DELETED status   */
  48:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    code.                                                               */
  49:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*                                                                        */
  50:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    It is important to note that the byte pool being deleted, or the    */
  51:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    memory associated with it should not be in use when this function   */
  52:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*    is called.                                                          */
  53:Middlewares/ST/threadx/common/src/tx_byte_pool_delete.c **** /*                                                                        */
