  33:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /*    Scott Larson, Microsoft Corporation                                 */
  34:Middlewares/ST/threadx/ports/cortex_m33/gnu/inc/tx_port.h **** /*                                                                        */
