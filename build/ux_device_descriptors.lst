  76:USBX/App/ux_device_descriptors.c **** /* String Device Framework :
  77:USBX/App/ux_device_descriptors.c ****  Byte 0 and 1 : Word containing the language ID : 0x0904 for US
  78:USBX/App/ux_device_descriptors.c ****  Byte 2       : Byte containing the index of the descriptor
  79:USBX/App/ux_device_descriptors.c ****  Byte 3       : Byte containing the length of the descriptor string
  80:USBX/App/ux_device_descriptors.c **** */
  81:USBX/App/ux_device_descriptors.c **** #if defined ( __ICCARM__ ) /* IAR Compiler */
  82:USBX/App/ux_device_descriptors.c **** #pragma data_alignment=4
  83:USBX/App/ux_device_descriptors.c **** #endif /* defined ( __ICCARM__ ) */
