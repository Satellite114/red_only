 213:USBX/App/ux_device_descriptors.c **** /**
 214:USBX/App/ux_device_descriptors.c ****   * @brief  USBD_Get_String_Framework
 215:USBX/App/ux_device_descriptors.c ****   *         Return the language_id_framework
 216:USBX/App/ux_device_descriptors.c ****   * @param  Length : Length of String_Framework
 217:USBX/App/ux_device_descriptors.c ****   * @retval Pointer to language_id_framework buffer
 218:USBX/App/ux_device_descriptors.c ****   */
 219:USBX/App/ux_device_descriptors.c **** uint8_t *USBD_Get_String_Framework(ULONG *Length)
 220:USBX/App/ux_device_descriptors.c **** {
 221:USBX/App/ux_device_descriptors.c ****   uint16_t len = 0U;
 222:USBX/App/ux_device_descriptors.c ****   uint8_t count = 0U;
 223:USBX/App/ux_device_descriptors.c **** 
 224:USBX/App/ux_device_descriptors.c ****   /* USER CODE BEGIN String_Framework0 */
 225:USBX/App/ux_device_descriptors.c **** 
 226:USBX/App/ux_device_descriptors.c ****   /* USER CODE END String_Framework0 */
 227:USBX/App/ux_device_descriptors.c **** 
 228:USBX/App/ux_device_descriptors.c ****   /* Set the Manufacturer language Id and index in USBD_string_framework */
 229:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING & 0xFF;
 230:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING >> 8;
 231:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_IDX_MFC_STR;
 232:USBX/App/ux_device_descriptors.c **** 
 233:USBX/App/ux_device_descriptors.c ****   /* Set the Manufacturer string in string_framework */
 234:USBX/App/ux_device_descriptors.c ****   USBD_Desc_GetString((uint8_t *)USBD_MANUFACTURER_STRING, USBD_string_framework + count, &len);
 235:USBX/App/ux_device_descriptors.c **** 
 236:USBX/App/ux_device_descriptors.c ****   /* Set the Product language Id and index in USBD_string_framework */
 237:USBX/App/ux_device_descriptors.c ****   count += len + 1;
 238:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING & 0xFF;
 239:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING >> 8;
 240:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_IDX_PRODUCT_STR;
 241:USBX/App/ux_device_descriptors.c **** 
 242:USBX/App/ux_device_descriptors.c ****   /* Set the Product string in USBD_string_framework */
 243:USBX/App/ux_device_descriptors.c ****   USBD_Desc_GetString((uint8_t *)USBD_PRODUCT_STRING, USBD_string_framework + count, &len);
 244:USBX/App/ux_device_descriptors.c **** 
 245:USBX/App/ux_device_descriptors.c ****   /* Set Serial language Id and index in string_framework */
 246:USBX/App/ux_device_descriptors.c ****   count += len + 1;
 247:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING & 0xFF;
 248:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_LANGID_STRING >> 8;
 249:USBX/App/ux_device_descriptors.c ****   USBD_string_framework[count++] = USBD_IDX_SERIAL_STR;
 250:USBX/App/ux_device_descriptors.c **** 
 251:USBX/App/ux_device_descriptors.c ****   /* Set the Serial number in USBD_string_framework */
 252:USBX/App/ux_device_descriptors.c ****   USBD_Desc_GetString((uint8_t *)USBD_SERIAL_NUMBER, USBD_string_framework + count, &len);
 253:USBX/App/ux_device_descriptors.c **** 
 254:USBX/App/ux_device_descriptors.c ****   /* Update final count to include the last string */
 255:USBX/App/ux_device_descriptors.c ****   count += len + 1;
 256:USBX/App/ux_device_descriptors.c **** 
 257:USBX/App/ux_device_descriptors.c ****   /* USER CODE BEGIN String_Framework1 */
