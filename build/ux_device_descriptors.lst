 574:USBX/App/ux_device_descriptors.c ****       (pdev->tclasslist[pdev->classId].Active == 0U))
 575:USBX/App/ux_device_descriptors.c ****   {
 576:USBX/App/ux_device_descriptors.c ****     /* Store the class parameters in the global tab */
 577:USBX/App/ux_device_descriptors.c ****     pdev->tclasslist[pdev->classId].ClassId = pdev->classId;
 578:USBX/App/ux_device_descriptors.c ****     pdev->tclasslist[pdev->classId].Active = 1U;
 579:USBX/App/ux_device_descriptors.c ****     pdev->tclasslist[pdev->classId].ClassType = class;
 580:USBX/App/ux_device_descriptors.c **** 
 581:USBX/App/ux_device_descriptors.c ****     if (class == CLASS_TYPE_HID)
 582:USBX/App/ux_device_descriptors.c ****     {
 583:USBX/App/ux_device_descriptors.c ****       pdev->tclasslist[pdev->classId].InterfaceType = UserHIDInterface[interface_idx];
 584:USBX/App/ux_device_descriptors.c **** 
 585:USBX/App/ux_device_descriptors.c ****       interface_idx++;
 586:USBX/App/ux_device_descriptors.c **** 
 587:USBX/App/ux_device_descriptors.c ****       if (interface_idx == sizeof(UserHIDInterface))
 588:USBX/App/ux_device_descriptors.c ****       {
 589:USBX/App/ux_device_descriptors.c ****         interface_idx = 0U;
 590:USBX/App/ux_device_descriptors.c ****       }
 591:USBX/App/ux_device_descriptors.c ****     }
 592:USBX/App/ux_device_descriptors.c **** 
 593:USBX/App/ux_device_descriptors.c ****     /* Call configuration descriptor builder and endpoint configuration builder */
 594:USBX/App/ux_device_descriptors.c ****     if (USBD_FrameWork_AddToConfDesc(pdev, Speed, pCmpstConfDesc) != UX_SUCCESS)
 595:USBX/App/ux_device_descriptors.c ****     {
 596:USBX/App/ux_device_descriptors.c ****       return UX_ERROR;
 597:USBX/App/ux_device_descriptors.c ****     }
 598:USBX/App/ux_device_descriptors.c ****   }
 599:USBX/App/ux_device_descriptors.c **** 
 600:USBX/App/ux_device_descriptors.c ****   UNUSED(cfgidx);
 601:USBX/App/ux_device_descriptors.c **** 
 602:USBX/App/ux_device_descriptors.c ****   return UX_SUCCESS;
