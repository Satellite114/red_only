 173:USBX/App/ux_device_descriptors.c **** /**
 174:USBX/App/ux_device_descriptors.c ****   * @brief  USBD_Get_Device_Framework_Speed
 175:USBX/App/ux_device_descriptors.c ****   *         Return the device speed descriptor
 176:USBX/App/ux_device_descriptors.c ****   * @param  Speed : HIGH or FULL SPEED flag
 177:USBX/App/ux_device_descriptors.c ****   * @param  length : length of HIGH or FULL SPEED array
 178:USBX/App/ux_device_descriptors.c ****   * @retval Pointer to descriptor buffer
 179:USBX/App/ux_device_descriptors.c ****   */
 180:USBX/App/ux_device_descriptors.c **** uint8_t *USBD_Get_Device_Framework_Speed(uint8_t Speed, ULONG *Length)
 181:USBX/App/ux_device_descriptors.c **** {
 182:USBX/App/ux_device_descriptors.c ****   uint8_t *pFrameWork = NULL;
 183:USBX/App/ux_device_descriptors.c ****   /* USER CODE BEGIN Device_Framework0 */
 184:USBX/App/ux_device_descriptors.c **** 
 185:USBX/App/ux_device_descriptors.c ****   /* USER CODE END Device_Framework0 */
 186:USBX/App/ux_device_descriptors.c **** 
 187:USBX/App/ux_device_descriptors.c ****   if (USBD_FULL_SPEED == Speed)
 188:USBX/App/ux_device_descriptors.c ****   {
 189:USBX/App/ux_device_descriptors.c ****     USBD_Device_Framework_Builder(&USBD_Device_FS, pDevFrameWorkDesc_FS,
 190:USBX/App/ux_device_descriptors.c ****                                   UserClassInstance, Speed);
 191:USBX/App/ux_device_descriptors.c **** 
 192:USBX/App/ux_device_descriptors.c ****     /* Get the length of USBD_device_framework_full_speed */
 193:USBX/App/ux_device_descriptors.c ****     *Length = (ULONG)(USBD_Device_FS.CurrDevDescSz + USBD_Device_FS.CurrConfDescSz);
 194:USBX/App/ux_device_descriptors.c **** 
 195:USBX/App/ux_device_descriptors.c ****     pFrameWork = pDevFrameWorkDesc_FS;
 196:USBX/App/ux_device_descriptors.c ****   }
 197:USBX/App/ux_device_descriptors.c ****   else
 198:USBX/App/ux_device_descriptors.c ****   {
 199:USBX/App/ux_device_descriptors.c ****     USBD_Device_Framework_Builder(&USBD_Device_HS, pDevFrameWorkDesc_HS,
 200:USBX/App/ux_device_descriptors.c ****                                   UserClassInstance, Speed);
ARM GAS  C:\usertemp\ccAyoptM.s 			page 5


 201:USBX/App/ux_device_descriptors.c **** 
 202:USBX/App/ux_device_descriptors.c ****     /* Get the length of USBD_device_framework_high_speed */
 203:USBX/App/ux_device_descriptors.c ****     *Length = (ULONG)(USBD_Device_HS.CurrDevDescSz + USBD_Device_HS.CurrConfDescSz);
