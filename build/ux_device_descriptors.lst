 455:USBX/App/ux_device_descriptors.c **** /**
 456:USBX/App/ux_device_descriptors.c ****   * @brief  USBD_Device_Framework_Builder
 457:USBX/App/ux_device_descriptors.c ****   *         Device Framework builder
 458:USBX/App/ux_device_descriptors.c ****   * @param  pdev: device instance
 459:USBX/App/ux_device_descriptors.c ****   * @param  pDevFrameWorkDesc: Pointer to the device framework descriptor
 460:USBX/App/ux_device_descriptors.c ****   * @param  UserClassInstance: type of the class to be added
 461:USBX/App/ux_device_descriptors.c ****   * @param  Speed: Speed parameter HS or FS
 462:USBX/App/ux_device_descriptors.c ****   * @retval status
 463:USBX/App/ux_device_descriptors.c ****   */
 464:USBX/App/ux_device_descriptors.c **** static uint8_t *USBD_Device_Framework_Builder(USBD_DevClassHandleTypeDef *pdev,
 465:USBX/App/ux_device_descriptors.c ****                                               uint8_t *pDevFrameWorkDesc,
 466:USBX/App/ux_device_descriptors.c ****                                               uint8_t *UserClassInstance,
 467:USBX/App/ux_device_descriptors.c ****                                               uint8_t Speed)
 468:USBX/App/ux_device_descriptors.c **** {
 469:USBX/App/ux_device_descriptors.c ****   static USBD_DeviceDescTypedef   *pDevDesc;
 470:USBX/App/ux_device_descriptors.c ****   static USBD_DevQualiDescTypedef *pDevQualDesc;
 471:USBX/App/ux_device_descriptors.c ****   uint8_t Idx_Instance = 0U;
 472:USBX/App/ux_device_descriptors.c **** 
 473:USBX/App/ux_device_descriptors.c ****   /* Set Dev and conf descriptors size to 0 */
 474:USBX/App/ux_device_descriptors.c ****   pdev->CurrConfDescSz = 0U;
 475:USBX/App/ux_device_descriptors.c ****   pdev->CurrDevDescSz = 0U;
 476:USBX/App/ux_device_descriptors.c **** 
 477:USBX/App/ux_device_descriptors.c ****   /* Set the pointer to the device descriptor area*/
 478:USBX/App/ux_device_descriptors.c ****   pDevDesc = (USBD_DeviceDescTypedef *)pDevFrameWorkDesc;
 479:USBX/App/ux_device_descriptors.c **** 
 480:USBX/App/ux_device_descriptors.c ****   /* Start building the generic device descriptor common part */
 481:USBX/App/ux_device_descriptors.c ****   pDevDesc->bLength = (uint8_t)sizeof(USBD_DeviceDescTypedef);
 482:USBX/App/ux_device_descriptors.c ****   pDevDesc->bDescriptorType = UX_DEVICE_DESCRIPTOR_ITEM;
 483:USBX/App/ux_device_descriptors.c ****   pDevDesc->bcdUSB = USB_BCDUSB;
 484:USBX/App/ux_device_descriptors.c ****   pDevDesc->bDeviceClass = 0x00;
 485:USBX/App/ux_device_descriptors.c ****   pDevDesc->bDeviceSubClass = 0x00;
 486:USBX/App/ux_device_descriptors.c ****   pDevDesc->bDeviceProtocol = 0x00;
 487:USBX/App/ux_device_descriptors.c ****   pDevDesc->bMaxPacketSize = USBD_MAX_EP0_SIZE;
 488:USBX/App/ux_device_descriptors.c ****   pDevDesc->idVendor = USBD_VID;
 489:USBX/App/ux_device_descriptors.c ****   pDevDesc->idProduct = USBD_PID;
 490:USBX/App/ux_device_descriptors.c ****   pDevDesc->bcdDevice = 0x0200;
 491:USBX/App/ux_device_descriptors.c ****   pDevDesc->iManufacturer = USBD_IDX_MFC_STR;
 492:USBX/App/ux_device_descriptors.c ****   pDevDesc->iProduct = USBD_IDX_PRODUCT_STR;
 493:USBX/App/ux_device_descriptors.c ****   pDevDesc->iSerialNumber = USBD_IDX_SERIAL_STR;
 494:USBX/App/ux_device_descriptors.c ****   pDevDesc->bNumConfigurations = USBD_MAX_NUM_CONFIGURATION;
 495:USBX/App/ux_device_descriptors.c ****   pdev->CurrDevDescSz += (uint32_t)sizeof(USBD_DeviceDescTypedef);
 496:USBX/App/ux_device_descriptors.c **** 
ARM GAS  C:\usertemp\ccAyoptM.s 			page 13


 497:USBX/App/ux_device_descriptors.c ****   /* Check if USBx is in high speed mode to add qualifier descriptor */
 498:USBX/App/ux_device_descriptors.c ****   if (Speed == USBD_HIGH_SPEED)
 499:USBX/App/ux_device_descriptors.c ****   {
 500:USBX/App/ux_device_descriptors.c ****     pDevQualDesc = (USBD_DevQualiDescTypedef *)(pDevFrameWorkDesc + pdev->CurrDevDescSz);
 501:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bLength = (uint8_t)sizeof(USBD_DevQualiDescTypedef);
 502:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bDescriptorType = UX_DEVICE_QUALIFIER_DESCRIPTOR_ITEM;
 503:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bcdDevice = 0x0200;
 504:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->Class = 0x00;
 505:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->SubClass = 0x00;
 506:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->Protocol = 0x00;
 507:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bMaxPacketSize = 0x40;
 508:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bNumConfigurations = 0x01;
 509:USBX/App/ux_device_descriptors.c ****     pDevQualDesc->bReserved = 0x00;
 510:USBX/App/ux_device_descriptors.c ****     pdev->CurrDevDescSz += (uint32_t)sizeof(USBD_DevQualiDescTypedef);
 511:USBX/App/ux_device_descriptors.c ****   }
 512:USBX/App/ux_device_descriptors.c **** 
 513:USBX/App/ux_device_descriptors.c ****   /* Build the device framework */
 514:USBX/App/ux_device_descriptors.c ****   while (Idx_Instance < USBD_MAX_SUPPORTED_CLASS)
 515:USBX/App/ux_device_descriptors.c ****   {
 516:USBX/App/ux_device_descriptors.c ****     if ((pdev->classId < USBD_MAX_SUPPORTED_CLASS) &&
 517:USBX/App/ux_device_descriptors.c ****         (pdev->NumClasses < USBD_MAX_SUPPORTED_CLASS) &&
 518:USBX/App/ux_device_descriptors.c ****         (UserClassInstance[Idx_Instance] != CLASS_TYPE_NONE))
 519:USBX/App/ux_device_descriptors.c ****     {
 520:USBX/App/ux_device_descriptors.c ****       /* Call the composite class builder */
 521:USBX/App/ux_device_descriptors.c ****       (void)USBD_FrameWork_AddClass(pdev,
 522:USBX/App/ux_device_descriptors.c ****                                     (USBD_CompositeClassTypeDef)UserClassInstance[Idx_Instance],
 523:USBX/App/ux_device_descriptors.c ****                                     0, Speed,
 524:USBX/App/ux_device_descriptors.c ****                                     (pDevFrameWorkDesc + pdev->CurrDevDescSz));
 525:USBX/App/ux_device_descriptors.c **** 
 526:USBX/App/ux_device_descriptors.c ****       /* Increment the ClassId for the next occurrence */
 527:USBX/App/ux_device_descriptors.c ****       pdev->classId ++;
 528:USBX/App/ux_device_descriptors.c ****       pdev->NumClasses ++;
 529:USBX/App/ux_device_descriptors.c ****     }
 530:USBX/App/ux_device_descriptors.c **** 
 531:USBX/App/ux_device_descriptors.c ****     Idx_Instance++;
 532:USBX/App/ux_device_descriptors.c ****   }
 533:USBX/App/ux_device_descriptors.c **** 
 534:USBX/App/ux_device_descriptors.c ****   /* Check if there is a composite class and update device class */
 535:USBX/App/ux_device_descriptors.c ****   if (pdev->NumClasses > 1)
 536:USBX/App/ux_device_descriptors.c ****   {
 537:USBX/App/ux_device_descriptors.c ****     pDevDesc->bDeviceClass = 0xEF;
 538:USBX/App/ux_device_descriptors.c ****     pDevDesc->bDeviceSubClass = 0x02;
 539:USBX/App/ux_device_descriptors.c ****     pDevDesc->bDeviceProtocol = 0x01;
 540:USBX/App/ux_device_descriptors.c ****   }
 541:USBX/App/ux_device_descriptors.c ****   else
 542:USBX/App/ux_device_descriptors.c ****   {
 543:USBX/App/ux_device_descriptors.c ****     /* Check if the CDC ACM class is set and update device class */
 544:USBX/App/ux_device_descriptors.c ****     if (UserClassInstance[0] == CLASS_TYPE_CDC_ACM)
 545:USBX/App/ux_device_descriptors.c ****     {
 546:USBX/App/ux_device_descriptors.c ****       pDevDesc->bDeviceClass = 0x02;
 547:USBX/App/ux_device_descriptors.c ****       pDevDesc->bDeviceSubClass = 0x02;
 548:USBX/App/ux_device_descriptors.c ****       pDevDesc->bDeviceProtocol = 0x00;
 549:USBX/App/ux_device_descriptors.c ****     }
 550:USBX/App/ux_device_descriptors.c ****   }
 551:USBX/App/ux_device_descriptors.c **** 
 552:USBX/App/ux_device_descriptors.c ****   return pDevFrameWorkDesc;
 553:USBX/App/ux_device_descriptors.c **** }
