 116:USBX/App/ux_device_descriptors.c ****         0x81, 0x02,       // INPUT (Data,Var,Abs)
 117:USBX/App/ux_device_descriptors.c ****         0x09, 0xFF,       // USAGE (Vendor Usage 1)
