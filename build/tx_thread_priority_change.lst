  44:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*                                                                        */
  45:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    This function changes the priority of the specified thread.  It     */
  46:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    also returns the old priority and handles preemption if the calling */
  47:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    thread is currently executing and the priority change results in a  */
  48:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    higher priority thread ready for execution.                         */
  49:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*                                                                        */
  50:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    Note: the preemption threshold is automatically changed to the new  */
  51:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*    priority.                                                           */
  52:Middlewares/ST/threadx/common/src/tx_thread_priority_change.c **** /*                                                                        */
